# TerraWatch environment variables
#
# Copy to `.env.local` for local dev. The `VITE_` prefixed vars are injected at
# build time and are safe to expose in the client bundle (the anon key is
# designed to be public and is scoped by Supabase row-level-security policies).

# Supabase (auth + bookmarks + Ask Terra quota)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
